{
  "rules": {
    "games": {
      "$gameId": {
        ".read": true,
        "operatorUid": {
          ".write": "auth != null && (!data.exists() || data.val() === auth.uid)"
        },
        "calledNumbers": { ".write": true },
        "currentNumber": { ".write": true },
        "queuedNumber": { ".write": true },
        "history": { ".write": true },
        "status": { ".write": true },
        "lastUpdatedAt": { ".write": true },
        "lastUpdatedBy": { ".write": true }
      }
    }
  }
}
